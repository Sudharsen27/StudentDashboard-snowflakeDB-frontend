# Local dev: omit NEXT_PUBLIC_API_BASE_URL to use /api → Next rewrites (see next.config).
# Production (Vercel): set to your Render API URL (no trailing slash), e.g.
# NEXT_PUBLIC_API_BASE_URL=https://snowflake-student-api.onrender.com
#
# Local rewrite target only (not needed when NEXT_PUBLIC points at Render):
# BACKEND_URL=http://127.0.0.1:5000

